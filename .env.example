# AML Open Framework — environment configuration
# Copy to .env and customize for your deployment.

# --- Database (API persistence) ---
DATABASE_URL=postgresql://aml:aml_dev_password@localhost:5432/aml

# --- Authentication ---
JWT_SECRET=change-me-in-production
# OIDC_ISSUER_URL=https://login.microsoftonline.com/{tenant}/v2.0  # Enable SSO
# OIDC_AUDIENCE=api://aml-framework

# --- API ---
API_RATE_LIMIT=600  # requests per minute per IP

# --- Dashboard ---
SPEC_PATH=examples/canadian_schedule_i_bank/aml.yaml  # spec to load in dashboard

# --- Integrations (all optional, no-op when unset) ---
# JIRA_URL=https://your-org.atlassian.net
# JIRA_TOKEN=your-api-token
# JIRA_PROJECT=AML
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...
