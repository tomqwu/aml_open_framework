<?xml version="1.0" encoding="UTF-8"?>
<!--
  Sample pacs.004 — Payment Return.
  Round-5 PR #5. Demonstrates the return-rate mining typology:
  ROAMR LTD (a corporate originator) had four outbound wires that
  came back from receiving banks in the same week with classic
  money-mule reason codes:
    - AC03 invalid creditor account number
    - AC04 closed creditor account
    - AM05 duplication
    - MD07 end-customer deceased
  Repeated returns from one originator is the canonical mule-network
  probing signal. UK PSR APP-fraud reimbursement mandate (Apr 2026
  full effect) makes catching this materially valuable.
-->
<Document xmlns="urn:iso:std:iso:20022:tech:xsd:pacs.004.001.11">
  <PmtRtr>
    <GrpHdr>
      <MsgId>RTR-2026-04-27-001</MsgId>
      <CreDtTm>2026-04-27T10:00:00</CreDtTm>
      <NbOfTxs>4</NbOfTxs>
      <SttlmInf>
        <SttlmMtd>CLRG</SttlmMtd>
      </SttlmInf>
    </GrpHdr>

    <TxInf>
      <RtrId>RTR-001</RtrId>
      <OrgnlEndToEndId>ROAMR-2026-04-20-A</OrgnlEndToEndId>
      <OrgnlUETR>11111111-1111-4111-8111-111111111111</OrgnlUETR>
      <OrgnlTxId>ORIG-A</OrgnlTxId>
      <RtrdIntrBkSttlmAmt Ccy="EUR">12000.00</RtrdIntrBkSttlmAmt>
      <IntrBkSttlmDt>2026-04-22</IntrBkSttlmDt>
      <RtrRsnInf>
        <Rsn><Cd>AC03</Cd></Rsn>
        <AddtlInf>Invalid creditor account number</AddtlInf>
      </RtrRsnInf>
      <OrgnlTxRef>
        <Dbtr>
          <Nm>ROAMR LTD</Nm>
          <PstlAdr><Ctry>GB</Ctry></PstlAdr>
        </Dbtr>
        <Cdtr>
          <Nm>SHELL VEHICLE 1</Nm>
          <PstlAdr><Ctry>CH</Ctry></PstlAdr>
        </Cdtr>
      </OrgnlTxRef>
    </TxInf>

    <TxInf>
      <RtrId>RTR-002</RtrId>
      <OrgnlEndToEndId>ROAMR-2026-04-21-B</OrgnlEndToEndId>
      <OrgnlUETR>22222222-2222-4222-8222-222222222222</OrgnlUETR>
      <OrgnlTxId>ORIG-B</OrgnlTxId>
      <RtrdIntrBkSttlmAmt Ccy="EUR">9500.00</RtrdIntrBkSttlmAmt>
      <IntrBkSttlmDt>2026-04-23</IntrBkSttlmDt>
      <RtrRsnInf>
        <Rsn><Cd>AC04</Cd></Rsn>
        <AddtlInf>Closed creditor account</AddtlInf>
      </RtrRsnInf>
      <OrgnlTxRef>
        <Dbtr>
          <Nm>ROAMR LTD</Nm>
          <PstlAdr><Ctry>GB</Ctry></PstlAdr>
        </Dbtr>
        <Cdtr>
          <Nm>SHELL VEHICLE 2</Nm>
          <PstlAdr><Ctry>CH</Ctry></PstlAdr>
        </Cdtr>
      </OrgnlTxRef>
    </TxInf>

    <TxInf>
      <RtrId>RTR-003</RtrId>
      <OrgnlEndToEndId>ROAMR-2026-04-22-C</OrgnlEndToEndId>
      <OrgnlUETR>33333333-3333-4333-8333-333333333333</OrgnlUETR>
      <OrgnlTxId>ORIG-C</OrgnlTxId>
      <RtrdIntrBkSttlmAmt Ccy="EUR">7800.00</RtrdIntrBkSttlmAmt>
      <IntrBkSttlmDt>2026-04-24</IntrBkSttlmDt>
      <RtrRsnInf>
        <Rsn><Cd>MD07</Cd></Rsn>
        <AddtlInf>End-customer deceased</AddtlInf>
      </RtrRsnInf>
      <OrgnlTxRef>
        <Dbtr>
          <Nm>ROAMR LTD</Nm>
          <PstlAdr><Ctry>GB</Ctry></PstlAdr>
        </Dbtr>
        <Cdtr>
          <Nm>MULE OPERATOR 3</Nm>
          <PstlAdr><Ctry>CH</Ctry></PstlAdr>
        </Cdtr>
      </OrgnlTxRef>
    </TxInf>

    <TxInf>
      <RtrId>RTR-004</RtrId>
      <OrgnlEndToEndId>ROAMR-2026-04-23-D</OrgnlEndToEndId>
      <OrgnlUETR>44444444-4444-4444-8444-444444444444</OrgnlUETR>
      <OrgnlTxId>ORIG-D</OrgnlTxId>
      <RtrdIntrBkSttlmAmt Ccy="EUR">15500.00</RtrdIntrBkSttlmAmt>
      <IntrBkSttlmDt>2026-04-25</IntrBkSttlmDt>
      <RtrRsnInf>
        <Rsn><Cd>AM05</Cd></Rsn>
        <AddtlInf>Duplication</AddtlInf>
      </RtrRsnInf>
      <OrgnlTxRef>
        <Dbtr>
          <Nm>ROAMR LTD</Nm>
          <PstlAdr><Ctry>GB</Ctry></PstlAdr>
        </Dbtr>
        <Cdtr>
          <Nm>MULE OPERATOR 4</Nm>
          <PstlAdr><Ctry>CH</Ctry></PstlAdr>
        </Cdtr>
      </OrgnlTxRef>
    </TxInf>
  </PmtRtr>
</Document>
