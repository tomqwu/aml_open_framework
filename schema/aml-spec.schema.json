{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aml-open-framework.org/schema/aml-spec.schema.json",
  "title": "AML Open Framework Spec",
  "description": "Spec contract for the aml.yaml file. One spec governs data contracts, detection rules, reviewer workflow, and regulator reporting.",
  "type": "object",
  "required": ["version", "program", "data_contracts", "rules", "workflow"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "enum": [1] },
    "program": { "$ref": "#/$defs/program" },
    "data_contracts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/data_contract" }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/rule" }
    },
    "workflow": { "$ref": "#/$defs/workflow" },
    "reporting": { "$ref": "#/$defs/reporting" },
    "retention_policy": { "$ref": "#/$defs/retention_policy" },
    "metrics": {
      "type": "array",
      "items": { "$ref": "#/$defs/metric" }
    },
    "reports": {
      "type": "array",
      "items": { "$ref": "#/$defs/report" }
    }
  },
  "$defs": {
    "program": {
      "type": "object",
      "required": ["name", "jurisdiction", "regulator", "owner", "effective_date"],
      "additionalProperties": false,
      "properties": {
        "name":           { "type": "string", "minLength": 1 },
        "jurisdiction":   { "type": "string", "minLength": 2 },
        "regulator":      { "type": "string", "minLength": 2 },
        "owner":          { "type": "string", "minLength": 1 },
        "effective_date": { "type": "string", "format": "date" }
      }
    },
    "data_contract": {
      "type": "object",
      "required": ["id", "source", "columns"],
      "additionalProperties": false,
      "properties": {
        "id":             { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "source":         { "type": "string", "minLength": 1 },
        "freshness_sla":  { "type": "string", "pattern": "^[0-9]+[smhd]$" },
        "columns": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/column" }
        },
        "quality_checks": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    },
    "column": {
      "type": "object",
      "required": ["name", "type"],
      "additionalProperties": false,
      "properties": {
        "name":        { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "type":        { "type": "string", "enum": ["string", "integer", "decimal", "boolean", "date", "timestamp"] },
        "nullable":    { "type": "boolean", "default": true },
        "pii":         { "type": "boolean", "default": false },
        "enum":        { "type": "array", "items": { "type": "string" } },
        "constraints": { "type": "array", "items": { "type": "string" } }
      }
    },
    "rule": {
      "type": "object",
      "required": ["id", "name", "severity", "regulation_refs", "logic", "escalate_to"],
      "additionalProperties": false,
      "properties": {
        "id":       { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "name":     { "type": "string", "minLength": 1 },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "status":   { "type": "string", "enum": ["active", "experimental", "deprecated"], "default": "active" },
        "evaluation_mode": { "type": "string", "enum": ["batch", "streaming", "both"], "default": "batch" },
        "regulation_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["citation", "description"],
            "additionalProperties": false,
            "properties": {
              "citation":    { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "logic":       { "$ref": "#/$defs/logic" },
        "escalate_to": { "type": "string" },
        "evidence":    { "type": "array", "items": { "type": "string" } },
        "tags":        { "type": "array", "items": { "type": "string" } }
      }
    },
    "logic": {
      "oneOf": [
        { "$ref": "#/$defs/logic_aggregation_window" },
        { "$ref": "#/$defs/logic_list_match" },
        { "$ref": "#/$defs/logic_custom_sql" },
        { "$ref": "#/$defs/logic_python_ref" },
        { "$ref": "#/$defs/logic_network_pattern" }
      ]
    },
    "logic_aggregation_window": {
      "type": "object",
      "required": ["type", "source", "group_by", "window", "having"],
      "additionalProperties": false,
      "properties": {
        "type":     { "const": "aggregation_window" },
        "source":   { "type": "string" },
        "filter":   { "type": "object" },
        "group_by": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "window":   { "type": "string", "pattern": "^[0-9]+[smhd]$" },
        "having":   { "type": "object", "minProperties": 1 }
      }
    },
    "logic_list_match": {
      "type": "object",
      "required": ["type", "source", "field", "list", "match"],
      "additionalProperties": false,
      "properties": {
        "type":      { "const": "list_match" },
        "source":    { "type": "string" },
        "field":     { "type": "string" },
        "list":      { "type": "string" },
        "match":     { "type": "string", "enum": ["exact", "fuzzy"] },
        "threshold": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "logic_custom_sql": {
      "type": "object",
      "required": ["type", "sql"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "custom_sql" },
        "sql":  { "type": "string", "minLength": 1 }
      }
    },
    "logic_python_ref": {
      "type": "object",
      "required": ["type", "callable", "model_id", "model_version"],
      "additionalProperties": false,
      "properties": {
        "type":          { "const": "python_ref" },
        "callable":      { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_.]*:[A-Za-z_][A-Za-z0-9_]*$" },
        "model_id":      { "type": "string" },
        "model_version": { "type": "string" }
      }
    },
    "logic_network_pattern": {
      "type": "object",
      "required": ["type", "having"],
      "additionalProperties": false,
      "properties": {
        "type":     { "const": "network_pattern" },
        "source":   { "type": "string" },
        "pattern":  { "type": "string", "enum": ["component_size", "common_counterparty"] },
        "max_hops": { "type": "integer", "minimum": 1, "maximum": 5 },
        "having":   { "type": "object", "minProperties": 1 }
      }
    },
    "workflow": {
      "type": "object",
      "required": ["queues"],
      "additionalProperties": false,
      "properties": {
        "queues": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "sla"],
            "additionalProperties": false,
            "properties": {
              "id":              { "type": "string" },
              "sla":             { "type": "string", "pattern": "^[0-9]+[smhd]$" },
              "next":            { "type": "array", "items": { "type": "string" } },
              "regulator_form":  { "type": "string" }
            }
          }
        }
      }
    },
    "reporting": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "forms": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["template"],
            "additionalProperties": true,
            "properties": {
              "template":         { "type": "string" },
              "mandatory_fields": { "type": "array", "items": { "type": "string" } },
              "trigger":          { "type": "object" }
            }
          }
        }
      }
    },
    "retention_policy": {
      "type": "object",
      "additionalProperties": { "type": "string", "pattern": "^[0-9]+[smhdy]$" }
    },
    "metric": {
      "type": "object",
      "required": ["id", "name", "category", "audience", "formula"],
      "additionalProperties": false,
      "properties": {
        "id":       { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "name":     { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "category": {
          "type": "string",
          "enum": ["operational", "effectiveness", "risk", "regulatory", "delivery"]
        },
        "audience": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["svp", "vp", "director", "manager", "pm", "developer", "business", "auditor", "analyst"]
          }
        },
        "owner":    { "type": "string" },
        "unit":     { "type": "string" },
        "formula":  { "$ref": "#/$defs/metric_formula" },
        "target":   { "type": "object" },
        "thresholds": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "green": { "type": "object" },
            "amber": { "type": "object" },
            "red":   { "type": "object" }
          }
        }
      }
    },
    "metric_formula": {
      "oneOf": [
        { "$ref": "#/$defs/formula_count" },
        { "$ref": "#/$defs/formula_sum" },
        { "$ref": "#/$defs/formula_ratio" },
        { "$ref": "#/$defs/formula_coverage" },
        { "$ref": "#/$defs/formula_sql" }
      ]
    },
    "formula_count": {
      "type": "object",
      "required": ["type", "source"],
      "additionalProperties": false,
      "properties": {
        "type":   { "const": "count" },
        "source": { "type": "string", "enum": ["alerts", "cases", "decisions", "rules", "txn", "customer"] },
        "filter": { "type": "object" },
        "distinct_by": { "type": "string" }
      }
    },
    "formula_sum": {
      "type": "object",
      "required": ["type", "source", "field"],
      "additionalProperties": false,
      "properties": {
        "type":   { "const": "sum" },
        "source": { "type": "string", "enum": ["alerts", "cases", "txn"] },
        "field":  { "type": "string" },
        "filter": { "type": "object" }
      }
    },
    "formula_ratio": {
      "type": "object",
      "required": ["type", "numerator", "denominator"],
      "additionalProperties": false,
      "properties": {
        "type":        { "const": "ratio" },
        "numerator":   { "$ref": "#/$defs/metric_formula" },
        "denominator": { "$ref": "#/$defs/metric_formula" }
      }
    },
    "formula_coverage": {
      "type": "object",
      "required": ["type", "universe", "covered_by"],
      "additionalProperties": false,
      "properties": {
        "type":       { "const": "coverage" },
        "universe":   { "type": "string", "enum": ["typologies", "jurisdictions", "products"] },
        "covered_by": { "type": "string", "enum": ["rule_tags", "regulation_refs"] }
      }
    },
    "formula_sql": {
      "type": "object",
      "required": ["type", "sql"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "sql" },
        "sql":  { "type": "string" }
      }
    },
    "report": {
      "type": "object",
      "required": ["id", "audience", "cadence", "sections"],
      "additionalProperties": false,
      "properties": {
        "id":       { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "title":    { "type": "string" },
        "audience": {
          "type": "string",
          "enum": ["svp", "vp", "director", "manager", "pm", "developer", "business", "auditor", "analyst"]
        },
        "cadence":  { "type": "string", "enum": ["daily", "weekly", "monthly", "quarterly", "annual", "on_demand"] },
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["title", "metrics"],
            "additionalProperties": false,
            "properties": {
              "title":   { "type": "string" },
              "metrics": { "type": "array", "items": { "type": "string" } },
              "commentary": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
